---
import { projects } from "../data/profile";
import Icon from "./Icon.astro";

const featured = projects.filter((p) => p.featured);
const rest = projects.filter((p) => !p.featured);
---

<section id="projects">
  <div class="inner">
    <div class="section-head reveal">
      <span class="num">03.</span>
      <h2>Research &amp; Projects</h2>
      <span class="line"></span>
    </div>

    <div class="featured">
      {
        featured.map((p) => (
          <article class={`feat-card reveal${p.image ? "" : " no-media"}`}>
            {p.image && (
              <div class="feat-media">
                <img src={p.image} alt={p.title} loading="lazy" />
              </div>
            )}
            <div class="feat-content">
              <p class="eyebrow">Featured</p>
              <h3>{p.title}</h3>
              <p class="feat-blurb">{p.blurb}</p>
              <div class="tags">
                {p.tags.map((t) => (
                  <span class="chip">{t}</span>
                ))}
              </div>
              {p.href && (
                <a class="feat-link" href={p.href} target="_blank" rel="noopener">
                  View on GitHub <Icon name="arrowRight" size={15} />
                </a>
              )}
            </div>
          </article>
        ))
      }
    </div>

    <h3 class="more-title reveal">Other projects</h3>
    <div class="grid">
      {
        rest.map((p) => (
          <article class="card reveal">
            <div class="card-top">
              <Icon name="link" size={22} class="card-folder" />
              {p.href && (
                <a href={p.href} target="_blank" rel="noopener" aria-label="GitHub">
                  <Icon name="github" size={20} />
                </a>
              )}
            </div>
            <h4>{p.title}</h4>
            <p>{p.blurb}</p>
            <div class="tags">
              {p.tags.map((t) => (
                <span class="mini-tag">{t}</span>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .featured {
    display: flex;
    flex-direction: column;
    gap: 28px;
    margin-bottom: 64px;
  }
  .feat-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color 0.25s ease, transform 0.25s ease;
  }
  .feat-card:hover {
    border-color: var(--muted);
    transform: translateY(-3px);
  }
  .feat-card.no-media {
    grid-template-columns: 1fr;
  }
  .feat-card:nth-child(even) .feat-media {
    order: 2;
  }
  .feat-media {
    background: var(--bg-soft);
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 220px;
    border-right: 1px solid var(--border);
  }
  .feat-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .feat-content {
    padding: 30px;
  }
  .feat-content h3 {
    font-size: 1.4rem;
    margin: 8px 0 14px;
  }
  .feat-blurb {
    color: var(--text-dim);
    font-size: 0.95rem;
    margin-bottom: 18px;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 18px;
  }
  .feat-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.88rem;
  }
  .feat-link:hover {
    text-decoration: underline;
  }

  .more-title {
    text-align: center;
    font-size: 1.4rem;
    margin-bottom: 36px;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 22px;
  }
  .card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 26px;
    transition: transform 0.25s ease, border-color 0.25s ease,
      background 0.25s ease;
    display: flex;
    flex-direction: column;
  }
  .card:hover {
    transform: translateY(-6px);
    background: var(--card-hover);
    border-color: var(--muted);
  }
  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }
  .card-folder {
    color: var(--accent);
  }
  .card-top a {
    color: var(--muted);
    transition: color 0.2s ease;
  }
  .card-top a:hover {
    color: var(--accent);
  }
  .card h4 {
    font-size: 1.15rem;
    margin-bottom: 10px;
  }
  .card p {
    color: var(--text-dim);
    font-size: 0.9rem;
    margin-bottom: 16px;
    flex: 1;
  }
  .mini-tag {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--muted);
  }
  .card .tags {
    margin-bottom: 0;
    gap: 12px;
  }

  @media (max-width: 760px) {
    .feat-card {
      grid-template-columns: 1fr;
    }
    .feat-card:nth-child(even) .feat-media {
      order: 0;
    }
    .feat-media {
      border-right: none;
      border-bottom: 1px solid var(--border);
      min-height: 180px;
    }
  }
</style>
