---
import { profile, education } from "../data/profile";
---

<section id="about">
  <div class="inner">
    <div class="section-head reveal">
      <span class="num">01.</span>
      <h2>About</h2>
      <span class="line"></span>
    </div>
    <div class="about-grid">
      <div class="about-text reveal">
        <p>{profile.intro}</p>
        <p>{profile.focus}</p>
        <p>
          I learn best by building: reproducing papers, training models from
          scratch, and writing about what worked and what did not. The
          <a href="/blog">writing</a> section is where I keep those notes.
        </p>
      </div>
      <aside class="about-edu reveal">
        <h3>Education</h3>
        {
          education.map((e) => (
            <div class="edu-item">
              <h4>{e.org}</h4>
              <p class="edu-degree">{e.degree}</p>
              <p class="edu-period">{e.period}</p>
              <p class="edu-detail">{e.detail}</p>
              {e.coursework && (
                <ul class="edu-courses">
                  {e.coursework.map((c) => (
                    <li>{c}</li>
                  ))}
                </ul>
              )}
            </div>
          ))
        }
      </aside>
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 48px;
    align-items: start;
  }
  .about-text p {
    color: var(--text-dim);
    margin-bottom: 18px;
  }
  .about-text a {
    color: var(--accent);
    border-bottom: 1px dashed var(--muted);
  }
  .about-edu {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 28px;
  }
  .about-edu h3 {
    font-size: 1.05rem;
    margin-bottom: 20px;
    color: var(--accent);
  }
  .edu-item:not(:last-child) {
    margin-bottom: 24px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--border-soft);
  }
  .edu-item h4 {
    font-size: 1rem;
  }
  .edu-degree {
    color: var(--text-dim);
    font-size: 0.95rem;
  }
  .edu-period {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--muted);
    margin: 4px 0 8px;
  }
  .edu-detail {
    color: var(--muted);
    font-size: 0.9rem;
  }
  .edu-courses {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 12px;
  }
  .edu-courses li {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    padding: 3px 9px;
    border-radius: 6px;
    background: var(--bg-soft);
    border: 1px solid var(--border-soft);
    color: var(--text-dim);
  }
  @media (max-width: 820px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>
