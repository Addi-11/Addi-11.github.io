---
import { profile, socials } from "../data/profile";
import Icon from "./Icon.astro";
---

<section id="home" class="hero">
  <canvas id="neural" class="neural"></canvas>
  <div class="hero-grid"></div>
  <div class="inner hero-inner">
    <p class="eyebrow hero-eyebrow">Hi, my name is</p>
    <h1 class="hero-name">{profile.name}.</h1>
    <h2 class="hero-sub">
      <span id="typed"></span><span class="caret">|</span>
    </h2>
    <p class="hero-blurb">{profile.focus}</p>

    <div class="hero-actions">
      <a href="#contact" class="btn btn-primary">Get in touch</a>
      <a href={profile.cvUrl} class="btn" target="_blank" rel="noopener">
        View CV
        <Icon name="arrowRight" size={16} />
      </a>
    </div>

    <div class="hero-socials">
      {
        socials.map((s) => (
          <a href={s.href} target="_blank" rel="noopener" aria-label={s.label}>
            <Icon name={s.icon} size={20} />
          </a>
        ))
      }
    </div>
  </div>
  <a href="#about" class="scroll-cue" aria-label="Scroll down">
    <span></span>
  </a>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    padding-top: 72px;
  }
  .neural {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }
  .hero-grid {
    position: absolute;
    inset: 0;
    z-index: 0;
    background:
      radial-gradient(
        ellipse 70% 60% at 70% 30%,
        var(--accent-glow),
        transparent 60%
      ),
      radial-gradient(
        ellipse 50% 50% at 10% 80%,
        rgba(0, 0, 0, 0.04),
        transparent 60%
      );
    pointer-events: none;
  }
  .hero-inner {
    position: relative;
    z-index: 2;
  }
  .hero-eyebrow {
    margin-bottom: 18px;
  }
  .hero-name {
    font-size: clamp(2.8rem, 8vw, 5rem);
    margin-bottom: 6px;
  }
  .hero-sub {
    font-size: clamp(1.6rem, 5vw, 3rem);
    color: var(--text-dim);
    min-height: 1.3em;
    margin-bottom: 26px;
  }
  #typed {
    color: var(--accent);
  }
  .caret {
    color: var(--accent);
    animation: blink 1s step-end infinite;
    font-weight: 300;
  }
  @keyframes blink {
    50% {
      opacity: 0;
    }
  }
  .hero-blurb {
    max-width: 600px;
    color: var(--muted);
    font-size: 1.05rem;
    margin-bottom: 34px;
  }
  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 40px;
  }
  .hero-socials {
    display: flex;
    gap: 20px;
  }
  .hero-socials a {
    color: var(--muted);
    transition: color 0.2s ease, transform 0.2s ease;
  }
  .hero-socials a:hover {
    color: var(--accent);
    transform: translateY(-3px);
  }
  .scroll-cue {
    position: absolute;
    bottom: 28px;
    left: 50%;
    transform: translateX(-50%);
    width: 26px;
    height: 42px;
    border: 2px solid var(--border);
    border-radius: 14px;
    z-index: 2;
  }
  .scroll-cue span {
    position: absolute;
    top: 8px;
    left: 50%;
    width: 4px;
    height: 8px;
    margin-left: -2px;
    background: var(--accent);
    border-radius: 2px;
    animation: scrollDot 1.8s ease-in-out infinite;
  }
  @keyframes scrollDot {
    0% {
      opacity: 0;
      transform: translateY(0);
    }
    40% {
      opacity: 1;
    }
    80% {
      opacity: 0;
      transform: translateY(14px);
    }
    100% {
      opacity: 0;
    }
  }
  @media (max-width: 720px) {
    .scroll-cue {
      display: none;
    }
  }
</style>

<script define:vars={{ roles: profile.roles }}>
  // Typed subtitle effect
  const typedEl = document.getElementById("typed");
  if (typedEl) {
    let roleIdx = 0;
    let charIdx = 0;
    let deleting = false;

    const tick = () => {
      const current = roles[roleIdx];
      if (!deleting) {
        typedEl.textContent = current.slice(0, ++charIdx);
        if (charIdx === current.length) {
          deleting = true;
          return setTimeout(tick, 1600);
        }
      } else {
        typedEl.textContent = current.slice(0, --charIdx);
        if (charIdx === 0) {
          deleting = false;
          roleIdx = (roleIdx + 1) % roles.length;
        }
      }
      setTimeout(tick, deleting ? 45 : 80);
    };
    tick();
  }

  // Neural constellation background
  const canvas = document.getElementById("neural");
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  if (canvas && !reduceMotion) {
    const ctx = canvas.getContext("2d");
    let w, h, dpr, nodes;
    const mouse = { x: -9999, y: -9999 };

    const resize = () => {
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      w = canvas.clientWidth;
      h = canvas.clientHeight;
      canvas.width = w * dpr;
      canvas.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      const density = Math.min(Math.floor((w * h) / 16000), 90);
      nodes = Array.from({ length: density }, () => ({
        x: Math.random() * w,
        y: Math.random() * h,
        vx: (Math.random() - 0.5) * 0.35,
        vy: (Math.random() - 0.5) * 0.35,
      }));
    };

    const draw = () => {
      ctx.clearRect(0, 0, w, h);
      for (const n of nodes) {
        n.x += n.vx;
        n.y += n.vy;
        if (n.x < 0 || n.x > w) n.vx *= -1;
        if (n.y < 0 || n.y > h) n.vy *= -1;

        const dxm = n.x - mouse.x;
        const dym = n.y - mouse.y;
        const dm = Math.hypot(dxm, dym);
        if (dm < 140) {
          const f = (140 - dm) / 140;
          n.x += (dxm / dm) * f * 1.3;
          n.y += (dym / dm) * f * 1.3;
        }
      }

      for (let i = 0; i < nodes.length; i++) {
        for (let j = i + 1; j < nodes.length; j++) {
          const a = nodes[i];
          const b = nodes[j];
          const d = Math.hypot(a.x - b.x, a.y - b.y);
          if (d < 130) {
            const o = (1 - d / 130) * 0.28;
            ctx.strokeStyle = `rgba(0, 0, 0, ${o})`;
            ctx.lineWidth = 1;
            ctx.beginPath();
            ctx.moveTo(a.x, a.y);
            ctx.lineTo(b.x, b.y);
            ctx.stroke();
          }
        }
      }

      for (const n of nodes) {
        ctx.fillStyle = "rgba(0, 0, 0, 0.45)";
        ctx.beginPath();
        ctx.arc(n.x, n.y, 1.7, 0, Math.PI * 2);
        ctx.fill();
      }
      requestAnimationFrame(draw);
    };

    window.addEventListener("resize", resize);
    window.addEventListener("mousemove", (e) => {
      const r = canvas.getBoundingClientRect();
      mouse.x = e.clientX - r.left;
      mouse.y = e.clientY - r.top;
    });
    window.addEventListener("mouseleave", () => {
      mouse.x = -9999;
      mouse.y = -9999;
    });
    resize();
    draw();
  }
</script>
